      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The Astrup Fearnley Museum presents \"Oceanic Dialogues\" (July 1 - August 30), bringing together artists from Norway, Australia, and Pacific Island nations. This exhibition examines our relationship with water and climate through multimedia installations, creating conversations between Nordic and Southern Hemisphere perspectives on environmental challenges.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The Astrup Fearnley Museum presents \"Oceanic Dialogues\" (July 1 - August 30), bringing together artists from Norway, Australia, and Pacific Island nations. This exhibition examines our relationship with water and climate through multimedia installations, creating conversations between Nordic and Southern Hemisphere perspectives on environmental challenges.",
          "href": null
