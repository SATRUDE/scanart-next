      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The National Museum's summer showcase \"Northern Light and Shadow\" (June 15 - September 5) explores how Scandinavian artists interpret their unique relationship with light. The exhibition features installations that play with Norway's extended summer daylight hours, creating immersive experiences that blend traditional Norwegian aesthetics with contemporary artistic expression.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The National Museum's summer showcase \"Northern Light and Shadow\" (June 15 - September 5) explores how Scandinavian artists interpret their unique relationship with light. The exhibition features installations that play with Norway's extended summer daylight hours, creating immersive experiences that blend traditional Norwegian aesthetics with contemporary artistic expression.",
          "href": null
        }
