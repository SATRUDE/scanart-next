    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Taking twelve years to complete and set over thirteen floors the Munch museum in Bjørvika is well worth a visit. Beyond seeing The Scream, essentially the Scandinavian Mona Lisa, the art throughout serves as a window into Munch’s life, and how his personal experiences not only shaped his work but would go on and shape an entire visual language.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
