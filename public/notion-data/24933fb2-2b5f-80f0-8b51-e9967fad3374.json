    "heading_3": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "How did you turn this passion into an online print store, and what for you makes Scandinavian Art different?",
            "link": null
          },
          "annotations": {
            "bold": true,
            "italic": false,
            "strikethrough": false,
