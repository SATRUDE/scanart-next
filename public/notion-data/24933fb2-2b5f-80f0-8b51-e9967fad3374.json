      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Firstly, it’s important to think about your style. Scandinavian interiors are often so clean and minimal leaving a lot of space for louder art pieces. However, if you already have a busy interior space then a simpler, paired back piece can work best.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
