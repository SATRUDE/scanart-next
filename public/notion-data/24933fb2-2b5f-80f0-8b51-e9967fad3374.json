  {
    "object": "block",
    "id": "24933fb2-2b5f-80c3-9c5d-ea4d710ad69e",
    "parent": {
      "type": "page_id",
      "page_id": "24933fb2-2b5f-80f0-8b51-e9967fad3374"
    },
    "created_time": "2025-08-08T15:02:00.000Z",
    "last_edited_time": "2025-08-08T15:02:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a75acbb5-0a51-455f-8c43-d19569c34453"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a75acbb5-0a51-455f-8c43-d19569c34453"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I was lucky enough to grow up five minutes from the beach in Bournemouth. After studying computer science and going on to work as a web designer internationally, it was finding love that brought me to Norway.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I was lucky enough to grow up five minutes from the beach in Bournemouth. After studying computer science and going on to work as a web designer internationally, it was finding love that brought me to Norway.",
          "href": null
        }
      ],
      "icon": null,
      "color": "default"
    },
    "archived": false
  },
  {
    "object": "block",
    "id": "24933fb2-2b5f-8022-85b3-fd47293875b6",
    "parent": {
      "type": "page_id",
      "page_id": "24933fb2-2b5f-80f0-8b51-e9967fad3374"
    },
    "created_time": "2025-08-08T15:02:00.000Z",
    "last_edited_time": "2025-08-08T15:02:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a75acbb5-0a51-455f-8c43-d19569c34453"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a75acbb5-0a51-455f-8c43-d19569c34453"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It was after buying my first home in Oslo that I dived into the world of interiors, and the diverse world of Scandinavian art. Packed with personalities, and as the perfect partner to a paired back sense of style, almost five years on it feels nice to be able to share a piece of Norway with the rest of the world, especially my home country.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "It was after buying my first home in Oslo that I dived into the world of interiors, and the diverse world of Scandinavian art. Packed with personalities, and as the perfect partner to a paired back sense of style, almost five years on it feels nice to be able to share a piece of Norway with the rest of the world, especially my home country.",
          "href": null
        }
      ],
      "icon": null,
      "color": "default"
    },
    "archived": false
