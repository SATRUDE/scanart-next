    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I think it’s hard to beat the classics, so my first recommendation has to be the National Gallery. The largest museum in the Nordics, and with ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
