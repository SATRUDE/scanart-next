    "type": "heading_3",
    "heading_3": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Shall we start with a little about you, what your background is, and why you’re so passionate about Scandinavian art?",
            "link": null
          },
          "annotations": {
            "bold": true,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Shall we start with a little about you, what your background is, and why you’re so passionate about Scandinavian art?",
          "href": null
        }
      ],
      "is_toggleable": false,
      "color": "default"
    },
    "archived": false
