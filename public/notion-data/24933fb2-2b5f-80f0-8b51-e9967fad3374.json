    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Nothing makes a house feel like a home more than when it reflects the people living there. And while we all have a favourite cup to drink from, or cushion on the sofa, it’s through the art we hang on our walls that we can create a space that is as unique as we are.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Nothing makes a house feel like a home more than when it reflects the people living there. And while we all have a favourite cup to drink from, or cushion on the sofa, it’s through the art we hang on our walls that we can create a space that is as unique as we are.",
          "href": null
        }
      ],
      "icon": null,
      "color": "default"
    },
    "archived": false
