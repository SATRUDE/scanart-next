    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "At its core, Scandinavian design celebrates natural materials, clean lines, and the concept of \"lagom\"—having just the right amount. This approach creates spaces that feel both serene and purposeful, where every element serves a function while contributing to the overall aesthetic harmony.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "At its core, Scandinavian design celebrates natural materials, clean lines, and the concept of \"lagom\"—having just the right amount. This approach creates spaces that feel both serene and purposeful, where every element serves a function while contributing to the overall aesthetic harmony.",
          "href": null
        }
      ],
